<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="RegressionSuite" verbose="1" parallel="false">

    <!-- AUTH FLOW (Same execution context) -->
    <test name="Authentication Flow">

        <classes>

            <!-- STEP 1: All LoginTests in ONE class declaration -->
            <class name="com.postbackdaddy.tests.auth.LoginTests">
                <methods>
                    <include name="testSuccessfulLogin"/>
                </methods>
            </class>

            <!-- STEP 2: Profile fetch (stores role ID and tenant ID) -->
            <class name="com.postbackdaddy.tests.auth.ProfileFetchTest">
                <methods>
                    <include name="testFetchProfile"/>
                </methods>
            </class>
            <!-- STEP 4: Fetch and cache tenants list -->
            <class name="com.postbackdaddy.tests.auth.GetTenantsListTest">
                <methods>
                    <include name="testGetTenantsList"/>
                    <include name="testGetTenantsWithCustomPagination"/>
                </methods>
            </class>
        </classes>
    </test>
    <!-- TENANT FLOW (Depends on auth token from login) -->
    <test name="Tenant Management Flow">
        <classes>
            <class name="com.postbackdaddy.tests.auth.TenantCreateTests">
                <methods>
                    <include name="testSuccessfulTenantCreation"/>
                </methods>
            </class>
        </classes>
    </test>
    <!-- LOGOUT FLOW (Independent execution) -->
    <test name="Logout Flow">
        <classes>
            <class name="com.postbackdaddy.tests.auth.LogoutTests">
                <methods>
                    <include name="testSuccessfulLogout"/>
                    <include name="testLogoutClearsToken"/>
                </methods>
            </class>
        </classes>
    </test>
    <test name="Suite Cleanup">
        <classes>
            <class name="com.postbackdaddy.tests.base.SuiteCleanup"/>
        </classes>
    </test>
</suite>
