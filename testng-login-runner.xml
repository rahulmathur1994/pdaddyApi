<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="LoginSuite" verbose="1" parallel="false">

    <!-- AUTH FLOW (Same execution context) -->
    <test name="Authentication Flow">

        <classes>

            <!-- STEP 1: Login -->
            <class name="com.postbackdaddy.tests.auth.LoginTests">
                <methods>
                    <include name="testSuccessfulLogin"/>
                </methods>
            </class>

            <!-- STEP 2: Profile fetch (reuses token) -->
            <class name="com.postbackdaddy.tests.auth.ProfileFetchTest">
                <methods>
                    <include name="testFetchProfile"/>
                </methods>
            </class>

            <!-- STEP 3: Remaining login validations -->
            <class name="com.postbackdaddy.tests.auth.LoginTests">
                <methods>
                    <include name="testLoginWithInvalidEmail"/>
                    <include name="testLoginWithInvalidPassword"/>
                    <include name="testTokenStorageAfterLogin"/>
                    <include name="testLoginReturnsTokens"/>
                </methods>
            </class>
        </classes>
    </test>

    <!-- LOGOUT FLOW (Independent execution) -->
    <test name="Logout Flow">

        <classes>
            <class name="com.postbackdaddy.tests.auth.LogoutTests">
                <methods>
                    <include name="testSuccessfulLogout"/>
                    <include name="testLogoutClearsToken"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Suite Cleanup">
        <classes>
            <class name="com.postbackdaddy.tests.base.SuiteCleanup"/>
        </classes>
    </test>

</suite>
