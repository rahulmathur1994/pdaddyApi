<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="RegressionSuiteTwo" verbose="1" parallel="false">

    <!-- ===================================================== -->
    <!-- AUTHENTICATION FLOW -->
    <!-- Login → Profile → Fetch Tenants -->
    <!-- ===================================================== -->
    <test name="Authentication Flow">

        <classes>

            <!-- STEP 1: Login -->
            <class name="com.postbackdaddy.tests.auth.LoginTests">
                <methods>
                    <include name="testSuccessfulLogin"/>
                </methods>
            </class>

            <!-- STEP 2: Profile -->
            <class name="com.postbackdaddy.tests.auth.ProfileFetchTest">
                <methods>
                    <include name="testFetchProfile"/>
                </methods>
            </class>

            <!-- STEP 3: Cache Tenants -->
            <class name="com.postbackdaddy.tests.auth.GetTenantsListTest">
                <methods>
                    <include name="testGetTenantsList"/>
                    <include name="testGetTenantsWithCustomPagination"/>
                </methods>
            </class>

        </classes>
    </test>


    <!-- ===================================================== -->
    <!-- TENANT MANAGEMENT FLOW -->
    <!-- Independent execution -->
    <!-- ===================================================== -->
    <test name="Tenant Management Flow">

        <classes>

            <!-- Tenant Creation (Optional Flow) -->
            <class name="com.postbackdaddy.tests.auth.TenantCreateTests">
                <methods>
                    <include name="testSuccessfulTenantCreation"/>
                </methods>
            </class>

            <!-- Tenant User Creation (Independent) -->
            <class name="com.postbackdaddy.tests.auth.TenantUserCreateTest">
                <methods>
                    <include name="testCreateTenantUser"/>
                </methods>
            </class>

            <!-- STEP 3: Fetch connectionConfig -->
            <class name="com.postbackdaddy.tests.auth.ConnectionConfigFetchTest">
                <methods>
                    <include name="testFetchTargetConnectionConfig"/>
                    <include name="testFetchSourceConfig"/>
                </methods>
            </class>

            <!-- STEP 3: Create Connection target -->
            <class name="com.postbackdaddy.tests.auth.ConnectionCreateTest">
                <methods>
                    <include name="testCreateTargetConnection"/>
                </methods>
            </class>
        </classes>
    </test>


    <!-- ===================================================== -->
    <!-- LOGOUT FLOW -->
    <!-- ===================================================== -->
    <test name="Logout Flow">

        <classes>
            <class name="com.postbackdaddy.tests.auth.LogoutTests">
                <methods>
                    <include name="testSuccessfulLogout"/>
                    <include name="testLogoutClearsToken"/>
                </methods>
            </class>
        </classes>

    </test>


    <!-- ===================================================== -->
    <!-- SUITE CLEANUP -->
    <!-- ===================================================== -->
    <test name="Suite Cleanup">

        <classes>
            <class name="com.postbackdaddy.tests.base.SuiteCleanup"/>
        </classes>

    </test>

</suite>